<header class="hdr" id="site-hdr">
  <div class="hdr-in">
    <a href="/" class="hdr-logo">MISTIQ</a>
    <nav class="hdr-nav">
      {%- for link in linklists[section.settings.menu].links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
      {%- if linklists[section.settings.menu].links.size == 0 -%}
        <a href="/collections/all">Shop</a>
        <a href="/pages/our-story">Our Story</a>
        <a href="/pages/contact">Contact</a>
      {%- endif -%}
    </nav>
    <div style="display:flex;align-items:center;gap:12px;">
      <a href="/cart" class="hdr-cart" aria-label="Cart ({{ cart.item_count }} items)">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        {%- if cart.item_count > 0 -%}<span class="hdr-cart-count">{{ cart.item_count }}</span>{%- endif -%}
      </a>
      <a href="/collections/all" class="hdr-cta">Shop Now</a>
      <button class="hdr-mob" id="mob-toggle" aria-label="Menu"><span></span><span></span></button>
    </div>
  </div>
</header>
<div id="mob-menu" style="position:fixed;inset:0;z-index:200;background:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:32px;opacity:0;visibility:hidden;transition:all .3s;">
  <button id="mob-close" style="position:absolute;top:20px;right:24px;font-size:1.5rem;font-weight:300;background:none;border:none;cursor:pointer;">&times;</button>
  {%- for link in linklists[section.settings.menu].links -%}
    <a href="{{ link.url }}" style="font-size:2rem;font-weight:800;letter-spacing:-1px;">{{ link.title }}</a>
  {%- endfor -%}
  {%- if linklists[section.settings.menu].links.size == 0 -%}
    <a href="/collections/all" style="font-size:2rem;font-weight:800;letter-spacing:-1px;">Shop</a>
    <a href="/pages/our-story" style="font-size:2rem;font-weight:800;letter-spacing:-1px;">Our Story</a>
    <a href="/pages/contact" style="font-size:2rem;font-weight:800;letter-spacing:-1px;">Contact</a>
  {%- endif -%}
  <a href="/cart" style="font-size:1rem;font-weight:500;color:#64748B;margin-top:16px;display:flex;align-items:center;gap:6px;"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>Cart ({{ cart.item_count }})</a>
</div>
<style>#mob-menu.open{opacity:1!important;visibility:visible!important;}</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
