<div class="page-hdr">
  <p class="sec-label">Collection</p>
  <h1>{{ collection.title }}</h1>
  {%- if collection.description != blank -%}<p>{{ collection.description }}</p>{%- endif -%}
</div>
<div style="max-width:var(--max-w);margin:0 auto;padding:0 0 80px;">
  <div class="pgrid">
    {%- for product in collection.products -%}
      <a href="{{ product.url }}" class="pcard">
        <div class="pcard-img">{%- if product.featured_image != blank -%}<img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" loading="lazy" width="800" height="800">{%- endif -%}</div>
        <div class="pcard-info">
          <p class="pcard-name">{{ product.title }}</p>
          <p class="pcard-meta">{{ product.type }}</p>
          <p class="pcard-price">{{ product.price | money }}{%- if product.compare_at_price > product.price -%}<s>{{ product.compare_at_price | money }}</s>{%- endif -%}</p>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection Page",
  "settings": []
}
{% endschema %}
