{%- assign col = section.settings.collection -%}
<section style="background:#fff;padding:80px 0;">
  <div class="sec" style="padding-top:0;padding-bottom:0;">
    <div class="sec-hdr">
      <div>
        <p class="sec-label">{{ section.settings.label }}</p>
        <h2 class="sec-title">{{ section.settings.heading }}</h2>
      </div>
      {%- if col != blank -%}
        <a href="{{ col.url }}">View all &rarr;</a>
      {%- endif -%}
    </div>
  </div>
  <div style="max-width:var(--max-w);margin:0 auto;">
    <div class="pgrid">
      {%- if col != blank -%}
        {%- for product in col.products limit: 6 -%}
          <a href="{{ product.url }}" class="pcard">
            <div class="pcard-img">
              {%- if product.featured_image != blank -%}
                <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" loading="lazy" width="800" height="800">
              {%- endif -%}
            </div>
            <div class="pcard-info">
              <p class="pcard-name">{{ product.title }}</p>
              <p class="pcard-meta">{{ product.metafields.custom.subtitle | default: product.type }}</p>
              <p class="pcard-price">{{ product.price | money }}
                {%- if product.compare_at_price > product.price -%}
                  <s>{{ product.compare_at_price | money }}</s>
                {%- endif -%}
              </p>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <div class="pcard">
            <div class="pcard-img" style="background:var(--gray-bg);"></div>
            <div class="pcard-info">
              <p class="pcard-name">Sample Product {{ i }}</p>
              <p class="pcard-meta">Add a collection in customizer</p>
              <p class="pcard-price">&euro;24.99</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "The collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Everything you need." },
    { "type": "collection", "id": "collection", "label": "Collection" }
  ],
  "presets": [{ "name": "Collection Grid" }]
}
{% endschema %}
