{%- assign p = section.settings.product -%}
<section style="border-top:1px solid var(--gray-border);border-bottom:1px solid var(--gray-border);padding:80px 0;">
  <div style="max-width:var(--max-w);margin:0 auto;padding:0 24px;">
    <div class="fsplit">
      <div>
        <p class="fsplit-label">{{ section.settings.label }}</p>
        <h2 class="fsplit-title">{{ section.settings.heading }}</h2>
        <p class="fsplit-body">{{ section.settings.body }}</p>
        <div class="fsplit-pts">
          {%- for block in section.blocks -%}
            <div class="fsplit-pt" {{ block.shopify_attributes }}>
              <span class="fsplit-chk"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></span>
              {{ block.settings.text }}
            </div>
          {%- endfor -%}
        </div>
      </div>
      <div>
        {%- if p != blank -%}
          <a href="{{ p.url }}" class="fsplit-card">
            <div class="fsplit-card-img">
              {%- if p.featured_image != blank -%}
                <img src="{{ p.featured_image | image_url: width: 800 }}" alt="{{ p.title }}" loading="lazy" width="800" height="600">
              {%- endif -%}
            </div>
            <p style="font-size:13.5px;font-weight:600;">{{ p.title }}</p>
            <p style="font-size:11.5px;color:var(--gray-light);margin-top:2px;">{{ p.description | strip_html | truncate: 60 }}</p>
            <div style="margin-top:12px;display:flex;align-items:center;justify-content:space-between;">
              <p style="font-size:14.5px;font-weight:700;">{{ p.price | money }}
                {%- if p.compare_at_price > p.price -%}
                  <span style="font-weight:400;color:var(--gray-light);text-decoration:line-through;margin-left:4px;">{{ p.compare_at_price | money }}</span>
                {%- endif -%}
              </p>
            </div>
          </a>
        {%- else -%}
          <div class="fsplit-card">
            <div class="fsplit-card-img" style="display:flex;align-items:center;justify-content:center;">
              <p style="color:var(--gray-light);font-size:13px;">Select a product in the customizer</p>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Product",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "The product" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "See every scent. Pick on mood." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Four scent intentions for your morning. You pick the one that fits your day." },
    { "type": "product", "id": "product", "label": "Product" }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point",
      "settings": [
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [{
    "name": "Featured Product",
    "blocks": [
      { "type": "point", "settings": { "text": "Eucalyptus, lavender, citrus, mint — all in one variety pack." }},
      { "type": "point", "settings": { "text": "Each pod lasts 2-3 showers. No single-use waste." }},
      { "type": "point", "settings": { "text": "Reusable holder included. Refill packs from €24.99." }}
    ]
  }]
}
{% endschema %}
